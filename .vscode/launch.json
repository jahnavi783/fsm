{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--dart-define=FLUTTER_FLAVOR=dev", "--flavor", "dev"]
    },
    {
      "name": "Staging",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--dart-define=FLUTTER_FLAVOR=staging"]
    },
    {
      "name": "Prod",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": ["--dart-define=FLUTTER_FLAVOR=prod"]
    },
    {
      "name": "Production Release",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": ["--dart-define=FLUTTER_FLAVOR=prod"]
    }
  ]
}
